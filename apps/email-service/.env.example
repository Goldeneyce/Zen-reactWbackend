# Google OAuth2 for Nodemailer
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token

# ── Kafka ── (leave ALL empty to use local brokers)
# Option A: Upstash (SASL/SSL)
# KAFKA_BROKER=your-cluster.upstash.io:9092
# KAFKA_USERNAME=your-upstash-username
# KAFKA_PASSWORD=your-upstash-password

# Option B: Aiven (mTLS) — set KAFKA_BROKER and cert paths, leave USERNAME/PASSWORD empty
# KAFKA_BROKER=your-cluster.aivencloud.com:13180
# KAFKA_SSL_CA_PATH=../../certs/ca.pem
# KAFKA_SSL_CERT_PATH=../../certs/service.cert
# KAFKA_SSL_KEY_PATH=../../certs/service.key
